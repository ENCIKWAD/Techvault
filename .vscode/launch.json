{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🐍 TechVault Backend (Python)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/backend/run.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "FLASK_ENV": "development"
            }
        },
        {
            "name": "🌐 TechVault Frontend (Chrome)",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "pathMapping": {
                "/": "${workspaceFolder}/frontend/"
            },
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "🚀 Full Stack Debug",
            "configurations": ["🐍 TechVault Backend (Python)", "🌐 TechVault Frontend (Chrome)"]
        }
    ]
}
